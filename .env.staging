# Staging environment variables template
# Copy to .env.local on staging deployment, or set in Vercel dashboard

NEXT_PUBLIC_ENV=staging

# Staging Supabase project (separate from production)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_anon_key

# API keys (can share with prod or use separate)
ANTHROPIC_API_KEY=sk-ant-api03-xxx
YOUTUBE_API_KEY=xxx
YOUTUBE_API_KEY_2=xxx
